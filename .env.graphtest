# Graph-provider test mode: `npm run dev -- --mode graphtest`
# Runs the REAL GraphStorageProvider against the local mock Graph server
# (ssf-verify/mock-graph.js on :3996) with a stub token — no MSAL, no tenant.
# .env.local still applies (CRN/VAT flow URLs etc).
VITE_GRAPH_FAKE=true
VITE_GRAPH_BASE=http://localhost:3996
