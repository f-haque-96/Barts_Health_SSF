# Production Environment Variables — TEMPLATE ONLY
# Copy to .env.production locally (git-ignored) or, preferably, set these in the
# CI / Azure Static Web Apps build configuration instead of a file.
# NOTE (June 2026 addendum): the Express API / App Service values below are from the
# retired architecture. The hybrid (SharePoint + Graph) config surface will be defined
# in delivery-plan step 4; expect VITE_API_URL to disappear.

# =============================================================================
# ENVIRONMENT MODE
# =============================================================================
VITE_APP_ENV=production

# =============================================================================
# BACKEND API (Express.js on Azure App Service)
# =============================================================================
# UPDATE WITH YOUR AZURE APP SERVICE URL
VITE_API_URL=https://your-app-service.azurewebsites.net/api

# =============================================================================
# AZURE AD AUTHENTICATION
# =============================================================================
# UPDATE WITH YOUR APP REGISTRATION DETAILS
VITE_AZURE_CLIENT_ID=your-client-id-from-app-registration
VITE_AZURE_TENANT_ID=your-barts-health-tenant-id
VITE_AZURE_REDIRECT_URI=https://your-verseone-intranet.nhs.uk

# =============================================================================
# FEATURE FLAGS - ALL DISABLED FOR PRODUCTION
# =============================================================================
VITE_ENABLE_TEST_BUTTONS=false
VITE_ENABLE_DEBUG_LOGGING=false
VITE_ENABLE_MOCK_AUTH=false

# =============================================================================
# APPLICATION URLS
# =============================================================================
# UPDATE WITH YOUR VERSEONE URL
VITE_INTRANET_URL=https://your-verseone-intranet.nhs.uk
VITE_APP_BASE_URL=https://your-verseone-intranet.nhs.uk

# Updated: Mar 2026 - CI compliance
