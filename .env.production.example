# Production Environment Variables — TEMPLATE ONLY (hybrid architecture, July 2026)
# Preferred: set these in the Azure Static Web Apps / CI build configuration,
# NOT in a committed file. A local .env.production copy is git-ignored.
#
# The Express/App Service variables from the retired architecture are gone —
# there is no VITE_API_URL any more. The production storage layer is Microsoft
# Graph → SharePoint (delivery-plan step 4).
#
# Full go-live swap list: docs/deployment/GO_LIVE_CHECKLIST.md

VITE_APP_ENV=production

# ── Verification proxy flows (Power Automate HTTP triggers) ────────────────
# CRN: HTTP GET URL of "SSF CRN - Companies House proxy" (playbook Task 8).
# If unset, CRN lookup degrades to manual verification.
VITE_CRN_FLOW_URL=

# VAT: HTTP GET URL of "SSF VAT - HMRC check proxy" (playbook Task 10).
# Go-live needs the PRODUCTION flow variant (api.service.hmrc.gov.uk + HMRC
# production credentials), not the sandbox one.
VITE_VAT_FLOW_URL=

# ── Azure AD (App Registration — values from IT, see IT_REQUEST_EMAIL.md) ──
VITE_AZURE_CLIENT_ID=
VITE_AZURE_TENANT_ID=
# Must exactly match a redirect URI registered on the App Registration
VITE_AZURE_REDIRECT_URI=

# ── Alemba call deep links ──────────────────────────────────────────────────
# {ref} is replaced with the numeric call number (format confirmed July 2026)
VITE_ALEMBA_CALL_URL=https://servicedeskbartshealth.alembacloud.com/production/Core.aspx?MMA&CORE_ENTITY=1&ENTITY_REF={ref}

# ── Supplier Information Pack (MS Forms share URL; Section 3 helper) ────────
VITE_SUPPLIER_PACK_FORM_URL=
# Pack lookup flow URL ("Fetch my supplier's answers" prefill)
VITE_PACK_FETCH_FLOW_URL=
