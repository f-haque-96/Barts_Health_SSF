# NHS Supplier Setup Form - Environment Variables
# Copy this file to .env.local for local development
# Copy to .env.production for production deployment

# =============================================================================
# ENVIRONMENT MODE
# =============================================================================
# 'development' = localStorage + mock auth (local dev only)
# 'production' = API backend + Azure AD auth
VITE_APP_ENV=development

# =============================================================================
# COMPANIES HOUSE CRN LOOKUP (Production - hybrid architecture)
# =============================================================================
# HTTP GET URL of the "SSF CRN - Companies House proxy" Power Automate flow
# (see docs/deployment/setup/07-browser-agent-playbook.md Task 8).
# If unset in a production build, CRN lookup degrades to manual verification.
VITE_CRN_FLOW_URL=

# =============================================================================
# BACKEND API CONFIGURATION (dev only - Express backend is FROZEN, see addendum)
# =============================================================================
# Express.js Backend API URL
VITE_API_URL=http://localhost:3001/api

# =============================================================================
# AZURE AD AUTHENTICATION (Production)
# =============================================================================
# Azure AD Application (client) ID from App Registration
VITE_AZURE_CLIENT_ID=

# Azure AD Tenant ID (Barts Health NHS Trust)
VITE_AZURE_TENANT_ID=

# Redirect URI after authentication (must match App Registration)
VITE_AZURE_REDIRECT_URI=http://localhost:5173

# =============================================================================
# DEV-ONLY FLAGS (read by code)
# =============================================================================
# Force the API provider in dev builds (normally dev uses localStorage demo mode)
VITE_USE_API=false

# =============================================================================
# SHAREPOINT REFERENCE (no secrets here - the SPA reaches SharePoint via Graph)
# =============================================================================
# SharePoint Site: https://bartshealth.sharepoint.com/sites/NHS-Supplier-Forms
# Lists:     SSF-Submissions, SSF-AuditTrail
# Libraries: SupplierDocuments (general), SensitiveDocuments (IDs/bank docs - restricted)
# Design:    docs/deployment/setup/06-hybrid-sharepoint-flows.md

# Updated: Jul 2026 - hybrid architecture; removed unused VITE_API_* flow endpoints
# and unread feature flags (VITE_ENABLE_*, VITE_APP_BASE_URL, VITE_INTRANET_URL)

# VAT verification flow URL (Power Automate HTTP trigger - playbook Task 10)
# Holds the HMRC OAuth credentials server-side; app calls it with ?vrn=<9-or-12-digits>
VITE_VAT_FLOW_URL=

# =============================================================================
# ALEMBA CALL DEEP LINKS (optional)
# =============================================================================
# Direct-link template for opening an Alemba call from the app; {ref} is
# replaced with the numeric call number. Leave unset until the real format is
# known and references render as plain text. NOTE: the ASM X address bar does
# NOT change per call (single-page app), so don't copy it from there - copy
# the link target out of an Alemba notification email, or ask the Alemba
# admin for the "direct link format for calls".
# Example shape (TBC): https://servicedeskbartshealth.alembacloud.com/production/Core.aspx?...&REF={ref}
VITE_ALEMBA_CALL_URL=
